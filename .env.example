LLM_PROVIDER=deepseek
LLM_FAST_MODEL=deepseek-v4-pro
LLM_PRO_MODEL=deepseek-v4-pro
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional Google fallback:
# LLM_PROVIDER=google
# GEMINI_API_KEY=your_gemini_api_key_here
# GEMINI_FAST_MODEL=gemini-2.0-flash-lite
# GEMINI_PRO_MODEL=gemini-2.5-pro
OPENALEX_API_KEY=your_openalex_api_key_here
OPENALEX_EMAIL=you@example.com
UNPAYWALL_EMAIL=you@example.com

# --- OpenAlex keyword rewriting (KeywordPlanner) ---
# Set to "false" to skip LLM reformulation and use domain_input directly.
OPENALEX_QUERY_REWRITE_ENABLED=true
# Maximum number of queries to execute per scan (default 10).
OPENALEX_QUERY_REWRITE_MAX_QUERIES=10
# Results fetched per individual query (default 20 for field scan, 5 for literature).
OPENALEX_QUERY_REWRITE_PER_QUERY_LIMIT=20
# Override the model used for reformulation (defaults to LLM_FAST_MODEL).
# OPENALEX_QUERY_REWRITE_MODEL=deepseek-v4-pro

# --- Literature harvester ---
# Final number of papers to keep after multi-query dedup (default 3).
LITERATURE_FINAL_LIMIT=3
